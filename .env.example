# cc-usage collector — example environment (employee machine).
#
# You normally do NOT edit this by hand: `bash install.sh` reads your Claude work
# account, enrolls you, and saves the values to ~/.claude/cc-usage/env.
#
# This repo is the COLLECTOR only — no dashboard/server code, no server secrets.

# Where usage is sent. Built into install.sh; you rarely change it.
CC_USAGE_INGEST_URL=…

# Your PERSONAL upload token (bound to your account). install.sh fetches this for
# you via team enrollment — you don't paste it by hand. Keep it secret.
CC_USAGE_INGEST_TOKEN=…

# Optional: override how you are identified. Defaults to your Claude OAuth account.
# CC_USAGE_USER=…

# Optional: restrict which Jira project keys are recognised (default KI,BI,ABT).
# CC_USAGE_JIRA_PROJECTS=KI,BI,ABT
