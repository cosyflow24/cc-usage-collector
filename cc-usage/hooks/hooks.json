{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap.sh\"", "timeout": 10 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/session-prompt.sh\"", "timeout": 10 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/capture-task.sh\"", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/ask-task.sh\"", "timeout": 10 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "CC_USAGE_PLUGIN_DIST=\"${CLAUDE_PLUGIN_ROOT}/dist\" bash \"${CLAUDE_PLUGIN_ROOT}/scripts/sync.sh\"", "timeout": 120 }
        ]
      }
    ]
  }
}
